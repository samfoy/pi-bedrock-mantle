{
  "name": "pi-bedrock-mantle",
  "private": false,
  "version": "1.0.2",
  "description": "Pi extension: all Bedrock Mantle models (GPT-5.5, DeepSeek, Qwen3, Mistral, Kimi, ...) via SigV4 — no long-term API key needed",
  "author": "Sam Fanning",
  "license": "MIT",
  "keywords": [
    "pi",
    "pi-extension",
    "bedrock",
    "bedrock-mantle",
    "gpt-5",
    "openai",
    "aws",
    "sigv4"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samfoy/pi-bedrock-mantle.git"
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf .tmp-test",
    "build": "echo 'nothing to build'",
    "check": "tsc --noEmit",
    "test": "rm -rf .tmp-test && tsc --noEmit false --outDir .tmp-test && node --test test/*.test.mjs"
  },
  "files": [
    "index.ts",
    "proxy.ts",
    "models.ts",
    "log.ts",
    "empty-completion.ts",
    "retry.ts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/credential-providers": "^3.799.0",
    "@smithy/signature-v4": "^5.1.1"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typescript": "^5.8.0"
  }
}
